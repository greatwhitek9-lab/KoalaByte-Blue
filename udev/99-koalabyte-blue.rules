# KoalaByte Blue stable serial device symlinks
# Installed by scripts/install_koalabyte_udev_rules.sh
#
# These rules make common ESP32-S3, Heltec, and nRF52840 USB serial boards easier
# to find from the Pi companion code. Use /dev/serial/by-id for exact matching
# when multiple boards use the same USB bridge chip.

# ESP32-S3 native USB/JTAG/CDC.
SUBSYSTEM=="tty", ATTRS{idVendor}=="303a", SYMLINK+="koalabyte-esp32-dualeye", MODE="0660", GROUP="dialout", TAG+="uaccess"

# Common CH340 USB serial bridge often used by ESP32 dev boards.
SUBSYSTEM=="tty", ATTRS{idVendor}=="1a86", ATTRS{idProduct}=="7523", SYMLINK+="koalabyte-esp32-dualeye", MODE="0660", GROUP="dialout", TAG+="uaccess"

# Common CP210x USB serial bridge often used by ESP32 dev boards.
SUBSYSTEM=="tty", ATTRS{idVendor}=="10c4", SYMLINK+="koalabyte-esp32-dualeye", MODE="0660", GROUP="dialout", TAG+="uaccess"

# Nordic/Heltec/nRF52840 style USB CDC serial boards.
SUBSYSTEM=="tty", ATTRS{idVendor}=="1915", SYMLINK+="koalabyte-heltec", MODE="0660", GROUP="dialout", TAG+="uaccess"
SUBSYSTEM=="tty", ATTRS{idVendor}=="239a", SYMLINK+="koalabyte-nrf52840", MODE="0660", GROUP="dialout", TAG+="uaccess"
