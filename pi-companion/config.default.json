  "eucalyptus": {
    "display_name": "eucalyptus",
    "description": "Always-on passive Bluetooth/BLE scanner and logger for authorized lab use.",
    "enabled": true,
    "capture_dir": "/blecaptures",
    "mode": "passive_ble_observation",
    "wigle_upload_enabled": false,
    "wigle_upload_interval_seconds": 1800
  },
  "urban_poaching": {
    "display_name": "Urban Poaching",
    "description": "Authorized BLE RSSI lab game using trend hints against owned lab beacons.",
    "enabled": true,
    "default_target_name": "EarTag-TX-Lab",
    "default_target_address": null,
    "scan_seconds": 4.0,
    "rounds": 12,
    "capture_radius_rssi": -48,
    "close_rssi": -60,
    "warm_rssi": -72,
    "log_dir": "logs/urban_poaching",
    "xp_reward_found": 25,
    "xp_reward_round": 1,
    "authorized_only": true
  },
  "koala_kapture": {
    "display_name": "Koala Kapture",
    "description": "Passive metadata capture for owned or written-scope lab BLE devices. No connection, pairing, write, disruption, or retransmission.",
    "enabled": true,
    "mode": "passive_metadata_capture",
    "output_dir": "/blecaptures/koala_kapture",
    "duration_seconds": 30.0,
    "scan_window_seconds": 5.0,
    "target_name": null,
    "target_address": null,
    "max_records": 1000,
    "include_manufacturer_data": true,
    "include_service_data": true,
    "authorized_only": true,
    "rf_transmission": false
  },
  "koala_kry": {
    "display_name": "Koala Kry",
    "description": "Offline replay simulator for metadata captured by Koala Kapture. Captured Bluetooth/RF over-the-air replay is blocked; optional review manifests document safe lab next steps.",
    "enabled": true,
    "mode": "captured_metadata_replay",
    "input_dir": "/blecaptures/koala_kapture",
    "output_dir": "logs/koala_kry_replay",
    "speed": 1.0,
    "loop": false,
    "max_records": null,
    "xp_reward": 5,
    "rf_transmission": false,
    "rf_transmit_request_policy": "blocked_review_manifest_only",
    "allow_captured_signal_replay": false,
    "allow_synthetic_owned_lab_beacon_reference": true
  },
  "ear_tag_tx_lab": {
    "display_name": "Ear Tag TX Lab",
    "description": "Synthetic owned-device BLE advertisement for signal-integrity observation. Does not replay captured packets.",
    "enabled": true,
    "mode": "synthetic_owned_lab_ble_advertisement",
    "firmware_path": "firmware/nrf52840-dk-lab-peripheral",
    "device_name": "EarTag-TX-Lab",
    "refresh_seconds": 5,
    "captured_signal_replay": false,
    "owned_device_required": true
  },
