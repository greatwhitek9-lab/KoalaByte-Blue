# KoalaByte Blue log rotation
# Install with: sudo install -m 0644 logrotate/koalabyte-blue /etc/logrotate.d/koalabyte-blue

/opt/KoalaByte-Blue/logs/**/*.log /opt/KoalaByte-Blue/logs/**/*.jsonl {
    weekly
    rotate 6
    compress
    delaycompress
    missingok
    notifempty
    copytruncate
}
