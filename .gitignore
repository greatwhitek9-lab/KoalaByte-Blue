# Local vendored Nordic/nRF Connect SDK and Zephyr SDK worktrees.
# These are intentionally populated on the Pi by scripts/vendor_nrf_connect_sdk.sh
# or scripts/setup_nrf_connect_sdk_toolchain.sh with VENDOR_NCS_IN_REPO=1.
# Do not push the full third-party SDK payload to this repo.
third_party/ncs/
third_party/zephyr-sdk-*/
!third_party/README.md
!third_party/ncs/README.md

