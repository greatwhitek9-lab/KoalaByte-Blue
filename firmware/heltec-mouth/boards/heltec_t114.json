{
  "build": {
    "arduino": {
      "ldscript": "nrf52840_s140_v6.ld"
    },
    "core": "nRF5",
    "cpu": "cortex-m4",
    "extra_flags": "-DARDUINO_NRF52840_FEATHER -DNRF52840_XXAA -DBOARD_HELTEC_T114=1",
    "f_cpu": "64000000L",
    "mcu": "nrf52840",
    "usb_product": "HT-n5262",
    "variant": "Heltec_T114_Board",
    "bsp": {"name": "adafruit"},
    "softdevice": {
      "sd_flags": "-DS140",
      "sd_name": "s140",
      "sd_version": "6.1.1",
      "sd_fwid": "0x00B6"
    },
    "bootloader": {"settings_addr": "0xFF000"}
  },
  "connectivity": ["bluetooth"],
  "debug": {
    "jlink_device": "nRF52840_xxAA",
    "openocd_target": "nrf52.cfg",
    "svd_path": "nrf52840.svd"
  },
  "frameworks": ["arduino"],
  "name": "Heltec Mesh Node T114 v2",
  "upload": {
    "maximum_ram_size": 235520,
    "maximum_size": 815104,
    "protocol": "nrfutil",
    "protocols": ["nrfutil", "jlink", "nrfjprog", "stlink"],
    "require_upload_port": true,
    "speed": 115200,
    "use_1200bps_touch": true,
    "wait_for_upload_port": true
  },
  "url": "https://heltec.org/",
  "vendor": "Heltec"
}
